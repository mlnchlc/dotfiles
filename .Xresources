! Dracula Xresources palette
*.foreground: #F8F8F2
*.background: #282A36
*.color0:     #000000
*.color8:     #4D4D4D
*.color1:     #FF5555
*.color9:     #FF6E67
*.color2:     #50FA7B
*.color10:    #5AF78E
*.color3:     #F1FA8C
*.color11:    #F4F99D
*.color4:     #BD93F9
*.color12:    #CAA9FA
*.color5:     #FF79C6
*.color13:    #FF92D0
*.color6:     #8BE9FD
*.color14:    #9AEDFE
*.color7:     #BFBFBF
*.color15:    #E6E6E6

XTerm.termName: xterm-256color
XTerm.vt100.saveLines: 10000
XTerm.vt100.faceName: IBMPlexMono:size=12
XTerm.vt100.internalBorder: 10
XTerm.vt100.locale: false
XTerm.vt100.utf8: true
//use standard copy-paste mechanism
xterm*VT100.Translations: #override \
    Shift <KeyPress> Insert: insert-selection(CLIPBOARD) \n\
    Ctrl Shift <Key>V:    insert-selection(CLIPBOARD) \n\
    Ctrl Shift <Key>C:    copy-selection(CLIPBOARD) \n\
    Ctrl <Btn1Up>: exec-formatted("xdg-open '%t'", PRIMARY)

UXTerm.termName: xterm-256color
UXTerm.vt100.saveLines: 10000
UXTerm.vt100.faceName: BlexMono Nerd Font Mono:size=12
UXTerm.vt100.internalBorder: 10
UXTerm.vt100.locale: false
UXTerm.vt100.utf8: true
//use standard copy-paste mechanism
UXterm*VT100.Translations: #override \
    Shift <KeyPress> Insert: insert-selection(CLIPBOARD) \n\
    Ctrl Shift <Key>V:    insert-selection(CLIPBOARD) \n\
    Ctrl Shift <Key>C:    copy-selection(CLIPBOARD) \n\
    Ctrl <Btn1Up>: exec-formatted("xdg-open '%t'", PRIMARY)


! scroll back to the bottom on keypress
URxvt*scrollTtyKeypress: true
! disable scrollback on secondary screens, eg,  less
URxvt.secondaryScreen: 1
URxvt.secondaryScroll: 0
URxvt.font: xft:BlexMono Nerd Font:style=Medium:size=11
URxvt.scrollBar: false
