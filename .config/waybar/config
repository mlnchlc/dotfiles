// -*- mode: json -*-
{
	"layer": "bottom",
	"position": "bottom",
	"margin-top": "0px",
	"margin-right": "0px",
	"margin-left": "0px",
	"margin-bottom":"0px",
	
	"modules-center": [
		"sway/workspaces",
		
	],

	"modules-left": [
		"custom/menu",
		"wlr/taskbar",
		"sway/mode"
	],

	"modules-right": [
		"tray",
		"clock",
		"idle_inhibitor",
		"network",
		"pulseaudio",
		"backlight",
		"cpu",		
		"memory",
		"temperature",
		"battery",
	],

	"sway/workspaces": {
		"disable-scroll": false,
 		"all-outputs": false,
 		"format": "{icon}",
		"format-default": "{name}",
		"format-icons": {
			"default": "´äĹ"
