    	},

	"clock": {
        	"format": "{:%A, %F, %H:%M}",
        	"tooltip": false
	},

	"pulseaudio": {
		"format": "{icon}{volume}% {format_source}",
		"format-bluetooth": "{icon}´Őö{volume}% {format_source}",
