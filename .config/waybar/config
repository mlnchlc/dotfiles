		"format": "{icon}",
		"icon-theme": "Gruvbox-Material-Dark",
		"icon-size": "16px",
		"on-click": "activate",
		"on-click-right": "minimize",
		"on-click-middle": "close"
	},

	"backlight": {
		"format": "{icon}{percent}%",
		"format-icons": ["´äĹ", "´ćů"],
		"on-scroll-up": "brightnessctl -d amdgpu_bl0 s +1%",
